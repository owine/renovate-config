{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "owine/* baseline — supply-chain hardened defaults. Pin everything, soak releases, escalate CVEs.",
  "extends": [
    "config:best-practices",
    "helpers:pinGitHubActionDigests",
    "security:openssf-scorecard",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "America/Chicago",
  "schedule": ["on monday"],
  "automergeSchedule": ["at any time"],
  "labels": ["dependencies"],
  "semanticCommitType": "deps",
  "semanticCommitScope": null,
  "configMigration": true,
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "pin",
  "separateMajorMinor": true,
  "separateMultipleMajor": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "minimumReleaseAge": "7 days",
  "osvVulnerabilityAlerts": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"],
    "automerge": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["on monday"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Major bumps — separate PR per package, 7-day soak, manual review required",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days",
      "automerge": false,
      "addLabels": ["major-update", "needs-review"]
    },
    {
      "description": "Pin Docker image and GitHub Action digests so a re-tagged image/action can't slip in",
      "matchManagers": ["dockerfile", "github-actions"],
      "pinDigests": true
    },
    {
      "description": "docker-compose: bump tags but never pin digests — keeps compose files readable for humans editing them by hand",
      "matchManagers": ["docker-compose"],
      "pinDigests": false
    },
    {
      "description": "Node version pins use LTS-aware versioning — Renovate's 'node' versioning scheme tracks LTS lines (22, 24, 26, ...) and skips Current/odd-numbered releases (23, 25, 27, ...). LTS-to-LTS major bumps still come as separate manual-review PRs via the major-bump rule above.",
      "matchPackageNames": ["node"],
      "matchDatasources": ["docker", "node-version"],
      "versioning": "node"
    }
  ]
}
